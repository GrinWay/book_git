function ssl_priv_key() {
	openssl genrsa -out priv.key 2048
}

function ssl_req() {
	local domain=$1
	local privKeyName="priv.key"
	local out="req.csr"

	if [[ -z "$domain" ]]; then
		echo "Pass domain as a first arg."
		return 1
	fi

	if [[ -n "$2" ]]; then
		privKeyName="$2"
	fi

	if [[ -n "$3" ]]; then
		out="$3"
	fi

	openssl req -new -key "$privKeyName" -out "$out" -subj "/CN=$domain"
}

function ssl_cert() {
	local out="$1"
	local privKeyName="priv.key"
	local req="req.csr"

        if [[ -z "$out" ]]; then
                echo "Pass out name as a first arg."
                return 1
        fi

        if [[ -n "$2" ]]; then
                privKeyName="$2"
        fi

        if [[ -n "$3" ]]; then
                req="$3"
        fi


	openssl x509 -req -days 365 -in "$req" -signkey "$privKeyName" -out "$out"
}


