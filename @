function mount() {  # 🔌 Монтирование
  local pathFrom="$1"
  local pathTo="$2"
  if [ -z "$pathFrom" ]; then
    pathFrom="/dev/sda2"
  fi
  if [ -z "$pathTo" ]; then
    pathTo="/mnt/flash"
  fi
  sudo mount -t ntfs-3g -o rw,uid=$(id -u),gid=$(id -g),umask=022 "$pathFrom" "$pathTo"
  folder "$pathTo"
}

function unmount() {  # ⛔ Размонтирование
  local pathTo="/mnt/flash"
  sudo umount "$pathTo"
}
