function php_set() {  # ⚙️ Установка PHP
  local phpVer="$1"
  local extensions=(
    cli fpm mysql xml mbstring curl gd intl bcmath zip
    soap json opcache readline sqlite3 exif imagick
    xmlrpc gmp pcntl
  )

  if [ -z "$phpVer" ]; then
    echo "❌ Usage: php_set <version> (e.g., 8.2 or 7.4)"
    return 1
  fi

  if ! command -v sudo &>/dev/null; then
    echo "❌ sudo is required to install packages"
    return 1
  fi

  echo "⚙️ Installing PHP $phpVer and extensions..."
  for ext in "${extensions[@]}"; do
    pkg="php${phpVer}-${ext}"
    if apt-cache show "$pkg" &>/dev/null; then
      echo "✅ Installing $pkg..."
      sudo apt install -y "$pkg" &>/dev/null
    else
      echo "⚠️ Package $pkg not found, skipping..."
    fi
  done

  if [ -f "/usr/bin/php$phpVer" ]; then
    sudo update-alternatives --set php "/usr/bin/php$phpVer"
    echo "🎯 Switched PHP CLI to $phpVer"
  else
    echo "❌ PHP $phpVer not installed"
  fi

  if [ -f "/etc/php/$phpVer/fpm/php-fpm.sock" ] || systemctl list-units --full -all | grep -q "php$phpVer-fpm"; then
    echo "💡 Ensure your webserver (nginx/apache) is using php$phpVer-fpm"
  fi

  echo "🎉 Done!"
}

function php_remove() {  # 🗑️ Удаление PHP
  local phpVer="$1"
  local extensions=(
    cli fpm mysql xml mbstring curl gd intl bcmath zip
    soap json opcache readline sqlite3 exif imagick
    xmlrpc gmp pcntl
  )

  if ! command -v sudo &>/dev/null; then
    echo "❌ sudo is required to remove packages"
    return 1
  fi

  # 🔎 Определяем версии PHP
  local versions=()
  if [ -n "$phpVer" ]; then
    versions=("$phpVer")
  else
    while read -r ver; do
      versions+=("$ver")
    done < <(dpkg -l | awk '/^ii  php[0-9]+\.[0-9]+/ {print $2}' | sed -E 's/php([0-9]+\.[0-9]+).*/\1/' | sort -u)
  fi

  if [ ${#versions[@]} -eq 0 ]; then
    echo "⚠️ No PHP versions found to remove"
    return 0
  fi

  for ver in "${versions[@]}"; do
    echo "🗑️ Removing PHP $ver and extensions..."
    for ext in "${extensions[@]}"; do
      pkg="php${ver}-${ext}"
      if dpkg -l | grep -q "^ii  $pkg"; then
        echo "✅ Removing $pkg..."
        sudo apt remove -y "$pkg" &>/dev/null
      else
        echo "⚠️ Package $pkg not installed, skipping..."
      fi
    done

    if [ -f "/usr/bin/php$ver" ]; then
      echo "🛑 PHP CLI $ver still exists, may need manual removal"
    else
      echo "🎯 PHP $ver removed successfully"
    fi
  done

  echo "💡 Consider updating alternatives after removal"
  echo "🎉 Done!"
}
