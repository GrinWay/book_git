function convert_pc() {  # 💻 Конверт для PC
  local dir="CONVERTED_PC"
  clear
  mkdir -p "./$dir"
  find . -maxdepth 1 -type f -regextype posix-extended \
    -iregex "^.*[.](mp4|mkv|avi|mov|wmv|avchd|flv)$" \
    -not -path "./CONVERTED*" -printf "%f\n" |
    xargs -I{} -n1 ffmpeg -i './{}' \
      -c:a aac -b:a 128k \
      -c:v h264_nvenc -preset p5 -rc vbr_hq -cq 23 \
      -b:v 6M -bufsize 16M \
      -map 0:a:0 -map 0:v:0 \
      -vf "scale=1920:1080:flags=lanczos,hqdn3d" \
      -profile:v high -level:v 4.2 \
      -hide_banner -loglevel error -stats -y "./$dir/{}"
}

function convert_tv() {  # 📺 Конверт для TV
  local dir="CONVERTED_TV"
  clear
  mkdir -p "./$dir"
  find . -maxdepth 1 -type f -regextype posix-extended \
    -iregex "^.*[.](mp4|mkv|avi|mov|wmv|avchd|flv)$" \
    -not -path "./CONVERTED*" -printf "%f\n" |
    xargs -I{} -n1 ffmpeg -i './{}' \
      -c:a mp3 -c:v libx264 -preset slow \
      -level:v 4.1 -crf 20 -pix_fmt yuv420p \
      -vf scale=1920:1080 \
      -map 0:a:0 -map 0:v:0 \
      -hide_banner -loglevel error -stats -y "./$dir/{}"
}

function convert_audio() {
  local dir="CONVERTED_AUDIO"
  local owner_user="${USER}"
  local owner_group="$(id -gn $USER)"

  clear
  mkdir -p "./$dir"

  # find через -print0 → безопасно для любых имён
  find . -maxdepth 1 -type f -regextype posix-extended \
    -iregex "^.*[.](mp3|flac|wav|m4a|ogg|wma|aac)$" \
    -not -path "./CONVERTED*" -print0 |
  while IFS= read -r -d '' file; do

    # Убираем ведущий ./ для удобства
    clean="${file#./}"

    echo "Конвертирую: $clean"

    # 1) Чистим имя файла
    safe_file="$(echo "$clean" | sed 's/[^A-Za-z0-9._ -]/_/g')"

    # Если имя поменялось — переименовываем
    if [[ "$safe_file" != "$clean" ]]; then
      mv "./$clean" "./$safe_file"
      clean="$safe_file"
    fi

    base="${clean%.*}"

    ### ------------------ OGG/OPUS (идеальный для Telegram) ------------------
    ffmpeg -nostdin -i "./$clean" \
      -vn \
      -c:a libopus \
      -b:a 128k \
      -ar 48000 \
      -ac 2 \
      -frame_duration 20 \
      -compression_level 10 \
      -application audio \
      -hide_banner -loglevel error -stats \
      -y "./$dir/${base}.ogg"

    ### ------------------ MP3 (максимально совместимый) ------------------
    ffmpeg -nostdin -i "./$clean" \
      -vn \
      -c:a libmp3lame \
      -b:a 320k \
      -ar 44100 \
      -ac 2 \
      -write_xing 1 \
      -hide_banner -loglevel error -stats \
      -y "./$dir/${base}.mp3"

    ### ------------------ Права и владелец ------------------
    chmod 777 "./$dir/${base}.ogg" "./$dir/${base}.mp3"
    chown "$owner_user":"$owner_group" "./$dir/${base}.ogg" "./$dir/${base}.mp3"

    echo "Готово: $clean"
    echo
  done
}


