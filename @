function fix() {  # 🛠️ Commit fix
  local fix="$1"
  if [ -z "$fix" ]; then
    fix="fix"
  fi
  git add -A
  git commit -m"$fix"
}

function isMergeCommit() {
	git show @^2 2>/dev/null && echo 'Yes, this commit is a merge commit' && return 0

	echo 'No merge commit'
	return 0
}

function rollback() {  # ⏪ Откат
  local to="$1"
  if [ -z "$to" ]; then
    to="master"
  fi
  git diff "$to" --name-only | xargs -I{} -n1 git checkout "$to" -- "{}"
}

function tn() {  # 🔢 Commit номер
  local n="$1"
  if [ -n "$n" ]; then
    git add .
    git commit -m"t_$n"
  else
    echo "Pass the number like: 1 or 2"
  fi
}

function diff() {  # 🔍 Diff с веткой
  local branch="master"
  if [[ $# -gt 0 && $1 != -* ]]; then
    branch="$1"
    shift
  fi
  local flags="$@"
  git diff "$branch"...@ $flags
}
